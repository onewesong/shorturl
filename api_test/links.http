@baseUrl = http://localhost:38080
@adminUser = admin
@adminPass = change-me

@code = api_test_demo_1
@targetUrl = https://example.com

### 登录并缓存 Cookie
# @name login
POST {{baseUrl}}/admin/api/v1/auth/login
Content-Type: application/json

{
  "username": "{{adminUser}}",
  "password": "{{adminPass}}"
}

?? status == 200

### 查看短链列表
GET {{baseUrl}}/admin/api/v1/links

?? status == 200

### 新建短链
POST {{baseUrl}}/admin/api/v1/links
Content-Type: application/json

{
  "code": "{{code}}",
  "target_url": "{{targetUrl}}"
}

?? status == 201 || status == 409

### 更新短链（把 id 改成列表接口里看到的数字）
@linkId = 1
PUT {{baseUrl}}/admin/api/v1/links/{{linkId}}
Content-Type: application/json

{
  "code": "{{code}}",
  "target_url": "{{targetUrl}}",
  "enabled": true
}

?? status == 200
